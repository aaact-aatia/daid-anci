<!DOCTYPE html>
<html lang="{{ lang | default('en') }}">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="{% if description %}{{ description }}{% else %}{% if lang == 'fr' %}{{ site.descriptionFr }}{% else %}{{ site.description }}{% endif %}{% endif %}" />
    {% if lang == 'fr' %}
      {% set siteName = site.titleFr %}
    {% else %}
      {% set siteName = site.title %}
    {% endif %}
    {% if page.url == '/en/' or page.url == '/fr/' %}
      <title>{{ siteName }}</title>
    {% else %}
      <title>{% if title %}{{ title }} | {% endif %}{{ siteName }}</title>
    {% endif %}

    <link
      rel="stylesheet"
      href="https://cdn.design-system.canada.ca/@gcds-core/css-shortcuts@1.0.1/dist/gcds-css-shortcuts.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdn.design-system.canada.ca/@gcds-core/components@1.0.0/dist/gcds/gcds.css"
    />
  </head>
  <body>
    {% include "partials/header.njk" %}

    <gcds-container id="main-content" layout="page" tag="main">
      {% if eleventyNavigation %}
        <gcds-grid columns="minmax(0, 1fr)" columns-desktop="320px minmax(0, 1fr)" tag="div" container="xl" alignment="center" class="xl:px-0 sm:px-600 px-225">
          {% include "partials/side-nav.njk" %}
          <div>
            {% if title %}
            <h1>{{ title }}</h1>
            {% endif %}
            {% if description %}
            <p>{{ description }}</p>
            {% endif %}
            {{ content | safe }}
          </div>
        </gcds-grid>
      {% else %}
        {% if title %}
        <h1>{{ title }}</h1>
        {% endif %}
        {% if description %}
        <p>{{ description }}</p>
        {% endif %}
        {{ content | safe }}
      {% endif %}
    </gcds-container>

    {% include "partials/footer.njk" %}

    <script
      type="module"
      src="https://cdn.design-system.canada.ca/@gcds-core/components@1.0.0/dist/gcds/gcds.esm.js"
    ></script>
  </body>
</html>
