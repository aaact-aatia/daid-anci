<!DOCTYPE html>
<html lang="{{ lang | default('en') }}">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="{% if description %}{{ description }}{% else %}{% if lang == 'fr' %}{{ site.descriptionFr }}{% else %}{{ site.description }}{% endif %}{% endif %}" />
    {% if lang == 'fr' %}
      {% set siteName = site.titleFr %}
    {% else %}
      {% set siteName = site.title %}
    {% endif %}
    {% if page.url == '/en/' or page.url == '/fr/' %}
      <title>{{ siteName }}</title>
    {% else %}
      <title>{% if title %}{{ title }} | {% endif %}{{ siteName }}</title>
    {% endif %}

    <link
      rel="stylesheet"
      href="https://cdn.design-system.canada.ca/@gcds-core/css-shortcuts@1.0.1/dist/gcds-css-shortcuts.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdn.design-system.canada.ca/@gcds-core/components@1.0.0/dist/gcds/gcds.css"
    />
  </head>
  <body>
    {% if lang == 'fr' %}
      {% if page.url == '/fr/a-propos/' %}
        {% set langHref = '/en/about/' %}
      {% else %}
        {% set langHref = '/en/' %}
      {% endif %}
    {% else %}
      {% if page.url == '/en/about/' %}
        {% set langHref = '/fr/a-propos/' %}
      {% else %}
        {% set langHref = '/fr/' %}
      {% endif %}
    {% endif %}

    <gcds-header lang-href="{{ langHref }}" skip-to-href="#main-content">
      <gcds-search slot="search"></gcds-search>
      {% if page.url == '/en/about/' or page.url == '/fr/a-propos/' %}
      <gcds-breadcrumbs slot="breadcrumb">
        {% if lang == 'fr' %}
        <gcds-breadcrumbs-item href="/fr/">{{ site.titleFr }}</gcds-breadcrumbs-item>
        <gcds-breadcrumbs-item href="/fr/a-propos/">A propos</gcds-breadcrumbs-item>
        {% else %}
        <gcds-breadcrumbs-item href="/en/">{{ site.title }}</gcds-breadcrumbs-item>
        <gcds-breadcrumbs-item href="/en/about/">About</gcds-breadcrumbs-item>
        {% endif %}
      </gcds-breadcrumbs>
      {% endif %}
    </gcds-header>

    <gcds-container id="main-content" layout="page" tag="main">
      {% if title %}
      <h1>{{ title }}</h1>
      {% endif %}
      {% if description %}
      <p>{{ description }}</p>
      {% endif %}
      {{ content | safe }}
    </gcds-container>

    {% if lang == 'fr' %}
    <gcds-footer
      lang="fr"
      display="full"
      contextual-heading="{{ site.titleFr }}"
      contextual-links='{"Accueil":"/fr/","A propos":"/fr/a-propos/"}'
    >
    </gcds-footer>
    {% else %}
    <gcds-footer
      lang="en"
      display="full"
      contextual-heading="{{ site.title }}"
      contextual-links='{"Home":"/en/","About":"/en/about/"}'
    >
    </gcds-footer>
    {% endif %}

    <script
      type="module"
      src="https://cdn.design-system.canada.ca/@gcds-core/components@1.0.0/dist/gcds/gcds.esm.js"
    ></script>
  </body>
</html>
