{% if lang == "en" %}
  {% set otherLang = "fr" %}
{% else %}
  {% set otherLang = "en" %}
{% endif %}
{% if otherLanguageUrl %}
  {% set langHref = otherLanguageUrl %}
{% elif otherLanguageTitle %}
  {% set langHref = "/" ~ otherLang ~ "/" ~ (otherLanguageTitle | stripTagsSlugify) ~ "/" %}
{% elif page.url == '/en/' or page.url == '/fr/' %}
  {% set langHref = "/" ~ otherLang ~ "/" %}
{% endif %}
<gcds-header {% if langHref %}lang-href="{{ langHref }}"{% endif %} skip-to-href="#main-content">
  <gcds-search slot="search"></gcds-search>
  {% if page.url != '/en/' and page.url != '/fr/' %}
  <gcds-breadcrumbs slot="breadcrumb">
    {% if lang == 'fr' %}
    <gcds-breadcrumbs-item href="/fr/">{{ site.titleFr }}</gcds-breadcrumbs-item>
    {% else %}
    <gcds-breadcrumbs-item href="/en/">{{ site.title }}</gcds-breadcrumbs-item>
    {% endif %}
    {% if parentPageUrl %}
    <gcds-breadcrumbs-item href="{{ parentPageUrl }}">{{ parentPageTitle }}</gcds-breadcrumbs-item>
    {% endif %}
    <gcds-breadcrumbs-item href="{{ page.url }}">{{ title }}</gcds-breadcrumbs-item>
  </gcds-breadcrumbs>
  {% endif %}
</gcds-header>
