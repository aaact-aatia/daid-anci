<header>
  <div class="site-header">
    <h1 class="site-title">
      <a href="{% if page.lang == 'fr' %}/fr/{% else %}/en/{% endif %}">
        {% if page.lang == 'fr' %}{{ site.titleFr }}{% else %}{{ site.title }}{% endif %}
      </a>
    </h1>
    <nav aria-label="{% if page.lang == 'fr' %}Navigation principale{% else %}Main navigation{% endif %}">
      <ul>
        {% if page.lang == 'fr' %}
        <li><a href="/fr/">Accueil</a></li>
        <li><a href="/fr/a-propos/">À propos</a></li>
        {% else %}
        <li><a href="/en/">Home</a></li>
        <li><a href="/en/about/">About</a></li>
        {% endif %}
      </ul>
    </nav>
  </div>
</header>
