{% set homeKey = "home-" + lang %}
{% set topNavTree = collections.all | eleventyNavigation(homeKey) %}
{% set navLabel = site.title if lang == "en" else site.titleFr %}
{% set homeUrl = ("/" + lang + "/") | url %}

<gcds-top-nav slot="menu" label="{{ navLabel }}" alignment="end">
  <gcds-nav-link href="{{ homeUrl }}" slot="home">{{ navLabel }}</gcds-nav-link>
  {% for entry in topNavTree %}
    {% set isActive = page.url == entry.url or eleventyNavigation.parent == entry.key %}
    <gcds-nav-link href="{{ entry.url | url }}"{% if isActive %} current{% endif %}>{{ entry.data.title or entry.title }}</gcds-nav-link>
  {% endfor %}
</gcds-top-nav>
